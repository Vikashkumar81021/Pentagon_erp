// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  empcode   String     @unique
  orders    Order[]

  roles     UserRole[]
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique

  users     UserRole[]
}

model UserRole {
  userId    Int
  roleId    Int

  user      User @relation(fields: [userId], references: [id])
  role      Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}
enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model Lead {
  id                Int      @id @default(autoincrement())
  organization_name String
  name_of_poc       String
  designation       String
  industry_sector   String
  phoneNumber       String?
  email             String?

  address           String?
  notes             String?
   priority          LeadPriority @default(MEDIUM)
  city            String
   status           String        @default("RAW") // RAW, ASSIGNED, CONTACTED, INTERESTED, NOT_INTERESTED, IN_PROGRESS, MEETING_SCHEDULED, CONVERTED, INACTIVE
  attemptsCount    Int           @default(0) 
   activities        LeadActivity[] 
     clientAccount     ClientAccount?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LeadActivity {
  id           String    @id @default(uuid())
  leadId       Int
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type         String    // CALL, EMAIL
  activityDate DateTime  @default(now())
  durationSec  Int       @default(0) // Call duration
  outcome      String    // No Response, Wrong Contact, Call Back Later, Interested, Not Interested, Meeting Requested
  remarks      String?
  followUpDate DateTime? @default(now())
  notes        String?
  mailStatus   String?   // Sent, Opened, Replied
  responses    String?   // Mail body summaries
  createdAt    DateTime  @default(now())
}
model ClientAccount {
  id                Int      @id @default(autoincrement())

  // Kis lead se convert hua
  leadId            Int      @unique
  lead              Lead     @relation(fields: [leadId], references: [id])

  organization_name String
  name_of_poc       String?
  designation       String?
  industry_sector   String?

  email             String?
  phoneNumber       String?

  address           String?
  city              String?

  status            String   @default("ACTIVE")

  orders            Order[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
model Notice{
   id                Int      @id @default(autoincrement())
  text String
    createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
enum PurchaseMode {
  GEM
  DIRECT_PURCHASE
  TENDER
}
model Order {
  id                Int       @id @default(autoincrement())

  // order_no          String    @unique
 purchaseMode      PurchaseMode
  clientAccountId   Int
  clientAccount     ClientAccount @relation(fields: [clientAccountId], references: [id])
  proposal       String?   // proposal no/name
  poNumber       String?   // customer PO
  salesPersonId     Int
  salesPerson       User      @relation(fields: [salesPersonId], references: [id])

  orderDate         DateTime  @default(now())
  status            String    @default("PENDING")

  totalAmount       Float

  shippingAddress   String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
} 